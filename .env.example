# ==============================================
# Silicon to Software (S2S) — Environment Configuration
# ==============================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in at least ONE LLM API key
# 3. (Optional) fill in GitHub token for auto-PR feature
# 4. Run:  docker compose up --build
#          OR: uvicorn main:app --reload

# ─── LLM API Keys — set at least ONE ──────────────────────────────────────────
# Claude (Anthropic) — recommended, best reasoning for hardware tasks
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# GLM-4 via Z.AI — good free-tier alternative
# Get key at: https://open.bigmodel.cn
GLM_API_KEY=

# DeepSeek-V3 — cost-effective, strong code generation
# Get key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# OpenAI — used for text-embedding-3-large embeddings (optional)
OPENAI_API_KEY=

# ─── LLM Model Selection ──────────────────────────────────────────────────────
# These are set automatically based on which key is present.
# Override only if you want a specific model variant.
# PRIMARY_MODEL=claude-opus-4-6
# FAST_MODEL=claude-haiku-4-5-20251001
# FALLBACK_MODEL=ollama/qwen2.5-coder:32b

# ─── Ollama (Air-Gap / On-Prem Fallback) ──────────────────────────────────────
# If no cloud LLM key is set, the pipeline falls back to Ollama automatically.
# Install: https://ollama.com  |  pull model: ollama pull qwen2.5-coder:32b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:32b

# ─── GitHub Integration (optional — enables auto-PR feature in P8c) ───────────
# REQUIRED PAT scopes (BOTH ticked, not just `repo`):
#   ✓ repo       — push code + create PR
#   ✓ workflow   — required because P8c writes .github/workflows/*.yml
# Create / re-issue at: https://github.com/settings/tokens?type=beta
# (For SAML SSO orgs: ALSO authorise the token at the org page — the
#  token silently 403s on push otherwise.)
GITHUB_TOKEN=
# `owner/repo` format — must already exist (private or public). The agent
# does NOT auto-create the repo.
GITHUB_REPO=your-org/your-repo-name
# Defaults to `true` whenever GITHUB_TOKEN is set. Set to `false` to skip
# git/PR creation even when the token is configured (useful in local dev).
GIT_ENABLED=false

# ─── GitHub push: bypass Git Credential Manager ───────────────────────────────
# On Windows / macOS, Git Credential Manager (GCM) intercepts every push
# and tries to open an OAuth dialog targeted at the `git-ecosystem`
# GitHub App — even when the remote URL has the PAT embedded. The user
# sees a "Connect to GitHub - Sign in" popup and "Authorize Git
# Credential Manager by Git Ecosystem" page, which blocks the headless
# pipeline.
#
# `_push_branch` already passes `-c credential.helper=` per-invocation
# to bypass GCM. This env var is a back-stop in case a future git
# version changes how that flag is handled — when set, the same flags
# are passed AND `GCM_INTERACTIVE=never` is forced.
GIT_BYPASS_CREDENTIAL_HELPER=true

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (used by docker compose):
DATABASE_URL=postgresql://hardware_pipeline:password@localhost:5432/hardware_pipeline

# SQLite (local dev, no Postgres needed):
# DATABASE_URL=sqlite:///./hardware_pipeline.db

# PostgreSQL password — also used in docker-compose.yml
POSTGRES_PASSWORD=change_me_in_production

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=component_datasheets

# ─── Component Search APIs (optional — pipeline works fine without these) ─────
# DigiKey API v3: https://developer.digikey.com
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
DIGIKEY_API_URL=https://api.digikey.com/v3

# Mouser Search API: https://api.mouser.com
MOUSER_API_KEY=
MOUSER_API_URL=https://api.mouser.com/api/v2

# ─── Password Gate (optional) ─────────────────────────────────────────────────
# Set to protect the app with a login page. Leave empty to disable.
# Recommended for Railway / public cloud deployments to protect your API keys.
# Share this password with judges / team members.
APP_PASSWORD=

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Silicon to Software (S2S)
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ─── Server ───────────────────────────────────────────────────────────────────
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
