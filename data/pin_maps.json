      "part_number": "MPN (uppercased as key)",
      "manufacturer": "vendor string",
      "package": "package name (e.g. LP2F-14, LFCSP-16)",
      "total_pins": "integer — pin count for the package",
      "pins": {
        "<pin_number>": {
          "name": "canonical pin name from datasheet",
          "type": "one of rf_input | rf_output | power | ground | control | clock | data | analog | digital | no_connect | ref"
        }
      }
    }
  },
